# GEMINI_API_KEY: required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: public URL where this app is hosted.
APP_URL="MY_APP_URL"

# JWT secret for authentication. Set this to a strong random value in Render/Vercel.
JWT_SECRET=

# Supabase project URL/ref.
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=

# Recommended for Render: split database variables.
# SUPABASE_DB_PASSWORD must be the Database Password from Supabase Project Settings > Database.
# It is NOT the anon key, service role key, JWT secret, or dashboard login password.
# SUPABASE_DB_HOST is optional. Leave it empty for the direct host db.[project-ref].supabase.co.
# If you use Supabase's transaction pooler, set SUPABASE_DB_HOST to the pooler host and SUPABASE_DB_PORT=6543.
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres

# Alternative: single PostgreSQL connection string.
# If the password has special URI characters (#, @, :, /, ?, &, %), URL-encode it first.
# Supabase direct connection example:
# DATABASE_URL="postgresql://postgres:[url-encoded-password]@db.[project-ref].supabase.co:5432/postgres"
# Supabase transaction pooler example for Render/Vercel/serverless:
# DATABASE_URL="postgresql://postgres.[project-ref]:[url-encoded-password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_URL=

# Generic PostgreSQL variables (used when SUPABASE_DB_PASSWORD and DATABASE_URL are not provided).
# For Supabase pooler, SQL_USER must be postgres.[project-ref], not just postgres.
SQL_HOST=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=

# Note: *.env files are ignored by git. Do not commit real credentials.